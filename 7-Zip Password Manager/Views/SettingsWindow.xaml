<!--
    SettingsWindow - 二级设置窗口
    
    功能：
      1. 密码列表路径设置 - 用户可浏览选择 .json 文件作为密码存储位置
      2. 关于信息 - 显示应用名称、版本号和简要说明
    
    设计说明：
      - 使用与主窗口相同的 DynamicResource 引用，支持亮色/暗色主题自动跟随
      - 窗口宽度固定，高度可拖拽调整（400~900），内容区可滚动，居中于父窗口
      - Owner 设为 MainWindow，关闭时不影响主窗口
      - 路径修改后通过 DialogResult 通知主窗口是否需要重新加载
-->
<Window x:Class="_7_Zip_Password_Manager.Views.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:loc="clr-namespace:_7_Zip_Password_Manager.Helpers"
        Title="{loc:T Key=settingsWindow.title}" Width="520" Height="580"
        MinHeight="400" MaxHeight="900"
        MinWidth="520" MaxWidth="520"
        ResizeMode="CanResize"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None"
        Icon="/Assets/smart-unzip-48.png"
        Background="{DynamicResource WindowBg}">

    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="32"
                      ResizeBorderThickness="0,0,0,6"
                      GlassFrameThickness="0"
                      CornerRadius="8"
                      UseAeroCaptionButtons="False" />
    </WindowChrome.WindowChrome>

    <Border BorderBrush="{DynamicResource ControlBorder}" BorderThickness="1"
            CornerRadius="8">
        <Grid>
            <Grid.Resources>
                <!-- ScrollBar 滑块 -->
                <Style x:Key="ScrollThumbStyle" TargetType="Thumb">
                    <Setter Property="OverridesDefaultStyle" Value="True" />
                    <Setter Property="IsTabStop" Value="False" />
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="Thumb">
                                <Border x:Name="Bd" Background="{DynamicResource ScrollThumb}"
                                        CornerRadius="3" Margin="1" />
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="Bd" Property="Background"
                                                Value="{DynamicResource ScrollThumbHover}" />
                                    </Trigger>
                                    <Trigger Property="IsDragging" Value="True">
                                        <Setter TargetName="Bd" Property="Background"
                                                Value="{DynamicResource ScrollThumbPressed}" />
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Style>

                <!-- 竖向 ScrollBar -->
                <Style TargetType="ScrollBar">
                    <Setter Property="Width" Value="8" />
                    <Setter Property="MinWidth" Value="8" />
                    <Setter Property="Background" Value="Transparent" />
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="ScrollBar">
                                <Track x:Name="PART_Track" IsDirectionReversed="True">
                                    <Track.Thumb>
                                        <Thumb Style="{StaticResource ScrollThumbStyle}" />
                                    </Track.Thumb>
                                </Track>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                    <Style.Triggers>
                        <Trigger Property="Orientation" Value="Horizontal">
                            <Setter Property="Width" Value="Auto" />
                            <Setter Property="Height" Value="8" />
                            <Setter Property="MinHeight" Value="8" />
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="ScrollBar">
                                        <Track x:Name="PART_Track">
                                            <Track.Thumb>
                                                <Thumb Style="{StaticResource ScrollThumbStyle}" />
                                            </Track.Thumb>
                                        </Track>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Trigger>
                    </Style.Triggers>
                </Style>

                <Style TargetType="Button">
                    <Setter Property="Background" Value="{DynamicResource ButtonBg}" />
                    <Setter Property="Foreground" Value="{DynamicResource ButtonFg}" />
                    <Setter Property="BorderBrush" Value="{DynamicResource ControlBorder}" />
                    <Setter Property="BorderThickness" Value="1" />
                    <Setter Property="Padding" Value="12,4" />
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="Bd"
                                        Background="{TemplateBinding Background}"
                                        BorderBrush="{TemplateBinding BorderBrush}"
                                        BorderThickness="{TemplateBinding BorderThickness}"
                                        Padding="{TemplateBinding Padding}"
                                        CornerRadius="4">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="Bd" Property="Background"
                                                Value="{DynamicResource ButtonHover}" />
                                    </Trigger>
                                    <Trigger Property="IsEnabled" Value="False">
                                        <Setter Property="Opacity" Value="0.45" />
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Style>
                <Style TargetType="TextBox">
                    <Setter Property="Background" Value="{DynamicResource InputBg}" />
                    <Setter Property="Foreground" Value="{DynamicResource InputFg}" />
                    <Setter Property="BorderBrush" Value="{DynamicResource ControlBorder}" />
                    <Setter Property="BorderThickness" Value="1" />
                    <Setter Property="CaretBrush" Value="{DynamicResource InputFg}" />
                    <Setter Property="Padding" Value="4,2" />
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="TextBox">
                                <Border x:Name="Bd"
                                        Background="{TemplateBinding Background}"
                                        BorderBrush="{TemplateBinding BorderBrush}"
                                        BorderThickness="{TemplateBinding BorderThickness}"
                                        Padding="{TemplateBinding Padding}"
                                        CornerRadius="4"
                                        SnapsToDevicePixels="True">
                                    <ScrollViewer x:Name="PART_ContentHost" />
                                </Border>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Style>
                <Style TargetType="GroupBox">
                    <Setter Property="BorderBrush" Value="{DynamicResource GroupBoxBorder}" />
                    <Setter Property="Foreground" Value="{DynamicResource WindowFg}" />
                    <Setter Property="Padding" Value="8" />
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="GroupBox">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="*" />
                                    </Grid.RowDefinitions>
                                    <Border Grid.Row="0" Grid.RowSpan="2"
                                            BorderBrush="{TemplateBinding BorderBrush}"
                                            BorderThickness="1"
                                            CornerRadius="4"
                                            Margin="0,8,0,0" />
                                    <Border Grid.Row="0" Margin="8,0,0,0" Padding="4,0"
                                            Background="{DynamicResource WindowBg}"
                                            HorizontalAlignment="Left"
                                            VerticalAlignment="Top">
                                        <ContentPresenter ContentSource="Header"
                                                          RecognizesAccessKey="True" />
                                    </Border>
                                    <ContentPresenter Grid.Row="1"
                                                      Margin="{TemplateBinding Padding}" />
                                </Grid>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Style>
            </Grid.Resources>
            <Grid.RowDefinitions>
                <RowDefinition Height="32" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <!--
                标题栏
                - 与主窗口风格一致的自定义标题栏
                - 仅保留关闭按钮（设置窗口不需要最小化/最大化）
            -->
            <Grid Grid.Row="0" Background="{DynamicResource TitleBarBg}">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="8,0">
                    <Image Source="/Assets/smart-unzip-32.png" Width="24" Height="24"
                           RenderOptions.BitmapScalingMode="HighQuality" Margin="0,0,8,0" />
                    <TextBlock Text="{loc:T Key=settingsWindow.title}" VerticalAlignment="Center"
                               FontSize="13" Foreground="{DynamicResource TitleBarFg}" />
                </StackPanel>
                <Button HorizontalAlignment="Right" Content="✕" Click="Close_Click"
                        Width="46" Height="32" FontSize="14"
                        Foreground="{DynamicResource TitleBarFg}"
                        Background="Transparent" BorderThickness="0"
                        WindowChrome.IsHitTestVisibleInChrome="True">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="Bd" Background="{TemplateBinding Background}">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="Bd" Property="Background"
                                            Value="{DynamicResource CloseHover}" />
                                    <Setter Property="Foreground"
                                            Value="{DynamicResource CloseHoverFg}" />
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </Grid>

            <!-- 设置内容区 -->
            <ScrollViewer Grid.Row="1"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled">
            <StackPanel Margin="16">

                <!--
                    ═══ 第一区：密码列表路径 ═══
                    
                    说明：
                      - 显示当前密码文件的完整路径
                      - "浏览" 按钮打开文件对话框，筛选 .json 文件
                      - "新建" 按钮打开保存对话框，可创建新的密码文件
                      - 修改路径后点击 "保存并加载" 应用更改
                      - 更改会持久化到 last_path.txt，下次启动自动使用新路径
                -->
                <GroupBox Header="{loc:T Key=settingsWindow.sectionPasswordPath}" Padding="8">
                    <StackPanel>
                        <TextBlock Text="{loc:T Key=settingsWindow.labelCurrentPwFile}" Margin="0,0,0,4" />

                        <DockPanel Margin="0,0,0,8">
                            <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                                <Button Content="{loc:T Key=mainWindow.btnBrowse}" Click="BrowsePath_Click"
                                        Padding="10,4" Margin="6,0,0,0" />
                                <Button Content="{loc:T Key=settingsWindow.btnNew}" Click="NewPath_Click"
                                        Padding="10,4" Margin="6,0,0,0" />
                            </StackPanel>
                            <TextBox x:Name="PathBox" IsReadOnly="True"
                                     VerticalContentAlignment="Center" />
                        </DockPanel>

                        <Button x:Name="SavePathBtn" Content="{loc:T Key=settingsWindow.btnSaveAndLoad}"
                                Click="SavePath_Click" HorizontalAlignment="Left"
                                Padding="16,6" IsEnabled="False" />
                    </StackPanel>
                </GroupBox>

                <!--
                    ═══ 第二区：关于 ═══
                    
                    说明：
                      - 显示应用程序名称和版本号
                      - 简要描述应用的功能和用途
                      - 版本号遵循语义化版本规范 (SemVer)
                -->
                <GroupBox Header="{loc:T Key=settingsWindow.section7Zip}" Padding="8" Margin="0,12,0,0">
                    <StackPanel>
                        <DockPanel>
                            <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                                <Button Content="{loc:T Key=settingsWindow.btnCheck}" Click="DetectSevenZip_Click"
                                        Padding="10,4" Margin="6,0,0,0" />
                                <Button Content="{loc:T Key=mainWindow.btnBrowse}" Click="BrowseSevenZip_Click"
                                        Padding="10,4" Margin="6,0,0,0" />
                            </StackPanel>
                            <TextBox x:Name="SevenZipPathBox" IsReadOnly="True"
                                     VerticalContentAlignment="Center" />
                        </DockPanel>
                        <TextBlock x:Name="SevenZipStatus" Margin="0,6,0,0"
                                   FontSize="12" Opacity="0.7" />
                    </StackPanel>
                </GroupBox>

                <GroupBox Header="{loc:T Key=settingsWindow.sectionIntegration}" Padding="8" Margin="0,12,0,0">
                    <StackPanel>
                        <CheckBox x:Name="ContextMenuCheck"
                                  Click="ContextMenu_Click"
                                  Foreground="{DynamicResource WindowFg}">
                            <TextBlock Text="{loc:T Key=settingsWindow.labelContextMenu}"
                                       TextWrapping="Wrap" />
                        </CheckBox>
                        <TextBlock x:Name="ContextMenuStatus" Margin="20,2,0,0"
                                   FontSize="12" Opacity="0.7" TextWrapping="Wrap" />
                        <TextBlock x:Name="ContextMenuDifferentInstanceHint" Margin="20,1,0,0"
                                   FontSize="12" Opacity="0.7" TextWrapping="Wrap" Visibility="Collapsed" />

                        <CheckBox x:Name="AutoCloseCheck" Margin="0,8,0,0"
                                  Click="AutoClose_Click"
                                  Foreground="{DynamicResource WindowFg}">
                            <TextBlock Text="{loc:T Key=settingsWindow.labelAutoClose}"
                                       TextWrapping="Wrap" />
                        </CheckBox>
                        <TextBlock x:Name="AutoCloseStatus" Margin="20,4,0,0"
                                   FontSize="12" Opacity="0.7" />
                    </StackPanel>
                </GroupBox>

                <GroupBox Header="{loc:T Key=settingsWindow.sectionPerformance}" Padding="8" Margin="0,12,0,0">
                    <StackPanel>
                        <DockPanel Margin="0,0,0,4">
                            <TextBlock Text="{loc:T Key=settingsWindow.labelParallelThreads}" VerticalAlignment="Center" />
                            <TextBlock DockPanel.Dock="Right" HorizontalAlignment="Right"
                                       VerticalAlignment="Center" Opacity="0.6" FontSize="12">
                                <Run x:Name="CpuLabelRun" /><Run x:Name="CpuCoreRun" /><Run x:Name="ThreadsSuffixRun" />
                            </TextBlock>
                        </DockPanel>
                        <DockPanel>
                            <TextBlock x:Name="ParallelValueText" DockPanel.Dock="Right"
                                       Width="52" TextAlignment="Center"
                                       VerticalAlignment="Center" FontWeight="SemiBold" />
                            <Slider x:Name="ParallelSlider"
                                    Minimum="1" SmallChange="1" IsSnapToTickEnabled="True"
                                    TickPlacement="BottomRight"
                                    ValueChanged="ParallelSlider_ValueChanged"
                                    VerticalAlignment="Center" Margin="0,0,8,0" />
                        </DockPanel>
                        <TextBlock Margin="0,4,0,0" FontSize="12" Opacity="0.5" TextWrapping="Wrap"
                                   Text="{loc:T Key=settingsWindow.labelParallelHint}" />
                    </StackPanel>
                </GroupBox>

                <GroupBox Padding="8" Margin="0,12,0,0">
                    <GroupBox.Header>
                        <StackPanel Orientation="Horizontal">
                            <Viewbox Width="14" Height="14" Margin="0,0,5,0">
                                <Canvas Width="16" Height="16">
                                    <Ellipse Width="14" Height="14" Canvas.Left="1" Canvas.Top="1"
                                             Stroke="{DynamicResource WindowFg}" StrokeThickness="1.2" />
                                    <Ellipse Width="7" Height="14" Canvas.Left="4.5" Canvas.Top="1"
                                             Stroke="{DynamicResource WindowFg}" StrokeThickness="0.9" />
                                    <Line X1="1.5" Y1="5.5" X2="14.5" Y2="5.5"
                                          Stroke="{DynamicResource WindowFg}" StrokeThickness="0.8" />
                                    <Line X1="1.5" Y1="10.5" X2="14.5" Y2="10.5"
                                          Stroke="{DynamicResource WindowFg}" StrokeThickness="0.8" />
                                </Canvas>
                            </Viewbox>
                            <TextBlock Text="{loc:T Key=settingsWindow.sectionLanguage}" />
                        </StackPanel>
                    </GroupBox.Header>
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                            <Button x:Name="LangZhBtn" Content="中文" Padding="16,4" Margin="0,0,8,0"
                                    Click="LangZh_Click" />
                            <Button x:Name="LangEnBtn" Content="English" Padding="16,4"
                                    Click="LangEn_Click" />
                        </StackPanel>
                        <TextBlock x:Name="LanguageStatus" FontSize="12" Opacity="0.7" />
                    </StackPanel>
                </GroupBox>

                <GroupBox Header="{loc:T Key=settingsWindow.sectionAbout}" Padding="8" Margin="0,12,0,0">
                    <Grid>
                        <Image Source="/Assets/smart-unzip-256.png"
                               Width="96" Height="96" Opacity="0.25"
                               HorizontalAlignment="Right" VerticalAlignment="Top"
                               Margin="0,-4,-4,0"
                               RenderOptions.BitmapScalingMode="HighQuality" />
                        <StackPanel>
                            <TextBlock FontSize="16" FontWeight="SemiBold"
                                       Text="{loc:T Key=settingsWindow.aboutAppName}" />
                            <TextBlock x:Name="AboutVersionText" Margin="0,4,0,0" />
                            <TextBlock Margin="0,8,0,0" TextWrapping="Wrap" Opacity="0.7"
                                       Text="{loc:T Key=settingsWindow.aboutDescription}" />
                            <TextBlock Margin="0,8,0,0" Opacity="0.7"
                                       Text="{loc:T Key=settingsWindow.aboutLicense}" />
                        </StackPanel>
                    </Grid>
                </GroupBox>

            </StackPanel>
            </ScrollViewer>
        </Grid>
    </Border>
</Window>
