    <SolidColorBrush x:Key="ScrollThumbPressed"  Color="#888888" />
    <SolidColorBrush x:Key="LogBg"              Color="#FAFAFA" />
    <SolidColorBrush x:Key="LogTimeFg"          Color="#999999" />
    <SolidColorBrush x:Key="LogInfoFg"          Color="#555555" />
    <SolidColorBrush x:Key="LogSuccessFg"       Color="#1A7F37" />
    <SolidColorBrush x:Key="LogWarningFg"       Color="#9D5D00" />
    <SolidColorBrush x:Key="LogErrorFg"         Color="#CF222E" />
    <SolidColorBrush x:Key="ProgressBarBg"      Color="#D6D6D6" />
    <SolidColorBrush x:Key="ProgressBarFill"     Color="#0078D4" />

</ResourceDictionary>
