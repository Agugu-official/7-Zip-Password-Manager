<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <SolidColorBrush x:Key="WindowBg"           Color="#F3F3F3" />
    <SolidColorBrush x:Key="WindowFg"           Color="#1E1E1E" />
    <SolidColorBrush x:Key="TitleBarBg"         Color="#E8E8E8" />
    <SolidColorBrush x:Key="TitleBarFg"         Color="#333333" />
    <SolidColorBrush x:Key="TitleBarBtnHover"   Color="#D0D0D0" />
    <SolidColorBrush x:Key="PinActiveBg"        Color="#0078D4" />
    <SolidColorBrush x:Key="PinActiveFg"        Color="#FFFFFF" />
    <SolidColorBrush x:Key="ThemeBtnBg"         Color="#E0E0E0" />
    <SolidColorBrush x:Key="ThemeBtnFg"         Color="#555555" />
    <SolidColorBrush x:Key="CloseHover"         Color="#E81123" />
    <SolidColorBrush x:Key="CloseHoverFg"       Color="#FFFFFF" />
    <SolidColorBrush x:Key="ControlBg"          Color="#FFFFFF" />
    <SolidColorBrush x:Key="ControlBorder"      Color="#CCCCCC" />
    <SolidColorBrush x:Key="ButtonBg"           Color="#E1E1E1" />
    <SolidColorBrush x:Key="ButtonFg"           Color="#1E1E1E" />
    <SolidColorBrush x:Key="ButtonHover"        Color="#C8C8C8" />

    <!-- 添加密码按钮高亮颜色（光主题） -->
    <SolidColorBrush x:Key="ButtonHighlightBg"  Color="#0078D4" />
    <SolidColorBrush x:Key="ButtonHighlightFg"  Color="#FFFFFF" />
    <SolidColorBrush x:Key="InputBg"            Color="#FFFFFF" />
    <SolidColorBrush x:Key="InputFg"            Color="#1E1E1E" />
    <SolidColorBrush x:Key="StatusBarBg"        Color="#E8E8E8" />
    <SolidColorBrush x:Key="StatusBarFg"        Color="#333333" />
    <SolidColorBrush x:Key="GroupBoxBorder"     Color="#CCCCCC" />
    <SolidColorBrush x:Key="DataGridHeaderBg"   Color="#E8E8E8" />
    <SolidColorBrush x:Key="HeaderHoverBg"     Color="#D8D8D8" />
    <SolidColorBrush x:Key="HeaderPressedBg"   Color="#CCCCCC" />
    <SolidColorBrush x:Key="DataGridRowAltBg"   Color="#F5F5F5" />
    <SolidColorBrush x:Key="DataGridSelectedBg" Color="#0078D4" />
    <SolidColorBrush x:Key="DataGridSelectedFg" Color="#FFFFFF" />
    <SolidColorBrush x:Key="DataGridInactiveBg" Color="Transparent" />
    <SolidColorBrush x:Key="DataGridInactiveFg" Color="#1E1E1E" />
    <SolidColorBrush x:Key="CheckBoxBg"         Color="#F0F0F0" />
    <SolidColorBrush x:Key="CheckBoxBorder"     Color="#999999" />
    <SolidColorBrush x:Key="CheckBoxCheck"      Color="#333333" />
